// Tenant Schema - This will be used to generate the Prisma Client for EACH company database
// Each time a company is created, we apply this schema to its private database.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/tenant"
}

datasource db {
  provider = "sqlite"
  url      = env("TENANT_DATABASE_URL")
}

// Configuration & Compliance
model FiscalSetting {
  id                String   @id @default(cuid())
  controlNumberSeq  Int      @default(1)    // Sequence for "Número de Control" (PROV/0102)
  invoiceNumberSeq  Int      @default(1)    // Sequence for "Factura"
  taxRate           Float    @default(16.0) // Default IVA 16%
  isDigitalInvoice  Boolean  @default(true)
  baseCurrencyId    String?  // Reference to the base currency (e.g., VEF or USD)
  updatedAt         DateTime @updatedAt
}

// Organization & Structure
model Branch {
  id            String   @id @default(cuid())
  name          String
  address       String?
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  products      Product[] 
  invoices      Invoice[]
  businessUnits BusinessUnit[]
  terminals     Terminal[]
}

model Terminal {
  id          String   @id @default(cuid())
  branchId    String
  code        String   // e.g., "CAJA-01"
  name        String
  prefix      String   // For offline sequencing (e.g., "01-")
  lastInvoice Int      @default(0)
  isActive    Boolean  @default(true)
  branch      Branch   @relation(fields: [branchId], references: [id])
  invoices    Invoice[]
}

model BusinessUnit {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id])
  invoices    Invoice[]
}

// Finance & Currency
model Currency {
  id          String   @id @default(cuid())
  code        String   @unique // USD, VEF, EUR
  name        String
  symbol      String
  isBase      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  exchangeRates ExchangeRate[]
  invoices    Invoice[]
}

model ExchangeRate {
  id          String   @id @default(cuid())
  currencyId  String
  rate        Float    // Rate relative to base currency
  effectiveAt DateTime @default(now())
  createdAt   DateTime @default(now())
  currency    Currency @relation(fields: [currencyId], references: [id])
}

model AccountingGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  type        String   // Asset, Liability, Equity, Revenue, Expense
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

// Inventory Module
model Product {
  id                String   @id @default(cuid())
  sku               String   @unique
  name              String
  description       String?
  costPrice         Float    @default(0)
  salePrice         Float    @default(0)
  stock             Int      @default(0)
  minStock          Int      @default(5)
  isExempt          Boolean  @default(false) // (E) in invoices for exempt items
  branchId          String?
  accountingGroupId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  branch            Branch?  @relation(fields: [branchId], references: [id])
  accountingGroup   AccountingGroup? @relation(fields: [accountingGroupId], references: [id])
  movements         InventoryMovement[]
}

model Invoice {
  id              String   @id @default(cuid())
  terminalId      String?
  branchId        String?
  businessUnitId  String?
  
  // Sequential IDs
  invoiceNumber   String?  @unique // Nullable for offline drafts until synced
  controlNumber   String?  @unique 
  
  // Offline Sync Management
  localId         String?  @unique // The UUID generated by the client
  isOffline       Boolean  @default(false)
  isSynced        Boolean  @default(true)
  offlineCreatedAt DateTime?
  
  date            DateTime @default(now())
  customerName    String
  customerRif     String
  customerAddress String?
  
  currencyId      String?
  exchangeRate    Float    @default(1.0)
  baseAmount      Float
  taxAmount       Float
  totalAmount     Float
  status          String   @default("issued") // issued, cancelled, DRAFT_OFFLINE, synced
  
  items           InvoiceItem[]
  auditLog        InvoiceAudit[]
  
  branch          Branch?  @relation(fields: [branchId], references: [id])
  businessUnit    BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  currency        Currency? @relation(fields: [currencyId], references: [id])
  terminal        Terminal? @relation(fields: [terminalId], references: [id])
}

model InventoryMovement {
  id              String   @id @default(cuid())
  productId       String
  type            String   // IN, OUT, ADJUSTMENT
  quantity        Int
  reference       String?  
  notes           String?
  userId          String
  
  // Offline support
  localId         String?  @unique
  isOffline       Boolean  @default(false)
  isSynced        Boolean  @default(true)
  
  product         Product  @relation(fields: [productId], references: [id])
  createdAt       DateTime @default(now())
}


model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String
  productName String
  quantity    Int
  unitPrice   Float
  taxRate     Float
  total       Float
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
}

model InvoiceAudit {
  id          String   @id @default(cuid())
  invoiceId   String
  action      String   // created, printed, cancelled
  reason      String?
  timestamp   DateTime @default(now())
  userId      String   // ID of the user who performed the action
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
}


generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/tenant"
}

datasource db {
  provider = "sqlite"
  url      = env("TENANT_DATABASE_URL")
}

// Configuration & Compliance (Art 7, 29, 31)
model FiscalSetting {
  id                String   @id @default("global-settings")
  digitalPrinterId  String?
  controlNumberRange String?  // e.g. "00-000001 al 00-010000" (Art 7.5)
  currentInvoiceSeq Int      @default(1)
  currentControlSeq Int      @default(1)
  taxRate           Float    @default(16.0) 
  baseCurrencyId    String?  
  updatedAt         DateTime @updatedAt
  
  digitalPrinter    DigitalPrinter? @relation(fields: [digitalPrinterId], references: [id])
}

model DigitalPrinter {
  id                String   @id @default(cuid())
  name              String   // Razón Social Imprenta Digital
  rif               String   @unique
  authNumber        String   // Número de Providencia de autorización
  authDate          DateTime // Fecha de la Providencia
  isActive          Boolean  @default(true)
  settings          FiscalSetting[]
}

// Organization & Structure
model Branch {
  id            String   @id @default(cuid())
  name          String
  legalName     String?  // Razón Social (Optional if different)
  rif           String?  // RIF (Optional if different)
  address       String?  
  phone         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  products      Product[] 
  invoices      Invoice[]
  businessUnits BusinessUnit[]
  terminals     Terminal[]
}

model Terminal {
  id          String   @id @default(cuid())
  branchId    String
  code        String   // e.g., "CAJA-01"
  name        String
  prefix      String   // For offline sequencing (Art 13)
  lastInvoice Int      @default(0)
  isActive    Boolean  @default(true)
  branch      Branch   @relation(fields: [branchId], references: [id])
  invoices    Invoice[]
}

model BusinessUnit {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  branch      Branch   @relation(fields: [branchId], references: [id])
}

// Finance & Currency
model Currency {
  id          String   @id @default(cuid())
  code        String   @unique // USD, VES, EUR
  name        String
  symbol      String
  isBase      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  exchangeRates ExchangeRate[]
  invoices    Invoice[]
}

model ExchangeRate {
  id          String   @id @default(cuid())
  currencyId  String
  rate        Float    
  effectiveAt DateTime @default(now())
  createdAt   DateTime @default(now())
  currency    Currency @relation(fields: [currencyId], references: [id])
}

model AccountingGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  type        String   
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

// Customers (Art 35)
model Customer {
  id          String   @id @default(cuid())
  name        String
  rif         String   @unique
  address     String?
  email       String?
  phone       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  invoices    Invoice[]
}

// Inventory Module
model Product {
  id                String   @id @default(cuid())
  sku               String   @unique
  name              String
  description       String?
  costPrice         Float    @default(0)
  salePrice         Float    @default(0)
  stock             Int      @default(0)
  minStock          Int      @default(5)
  isExempt          Boolean  @default(false) // Art 7.8 (E)
  branchId          String?
  accountingGroupId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  branch            Branch?  @relation(fields: [branchId], references: [id])
  accountingGroup   AccountingGroup? @relation(fields: [accountingGroupId], references: [id])
  movements         InventoryMovement[]
  invoiceItems      InvoiceItem[]
}

model InventoryMovement {
  id              String   @id @default(cuid())
  productId       String
  type            String   // IN, OUT, ADJUSTMENT
  quantity        Int
  reference       String?
  notes           String?
  userId          String?
  createdAt       DateTime @default(now())
  product         Product  @relation(fields: [productId], references: [id])
}

// Invoicing (Salida de Documentos Fiscales)
model Invoice {
  id              String   @id @default(cuid())
  type            String   @default("FACTURA") // Art 2
  terminalId      String?
  branchId        String?
  customerId      String?
  
  // Sequential & Fiscal IDs (Art 7)
  invoiceNumber   String?  @unique 
  controlNumber   String?  @unique 
  series          String?  // Art 13
  
  // Printer Data Snapshot (Art 7.14)
  printerRif      String?  
  printerAuth     String?
  printerAuthDate DateTime?
  controlAssignedAt DateTime? @default(now())
  
  // Sync Management
  localId         String?  @unique 
  isOffline       Boolean  @default(false)
  isSynced        Boolean  @default(true)
  offlineCreatedAt DateTime?
  
  date            DateTime @default(now()) // Art 7.6 (Fecha y Hora)
  
  // Customer Data Snapshot (Art 7.7)
  customerName    String
  customerRif     String
  customerAddress String?
  
  currencyId      String?
  exchangeRate    Float    @default(1.0)
  baseAmount      Float
  taxAmount       Float
  igtfAmount      Float    @default(0.0) // Art 32.2 opt
  totalAmount     Float
  status          String   @default("issued") // issued, cancelled
  
  items           InvoiceItem[]
  auditLog        InvoiceAudit[]
  
  branch          Branch?  @relation(fields: [branchId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  currency        Currency? @relation(fields: [currencyId], references: [id])
  terminal        Terminal? @relation(fields: [terminalId], references: [id])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  productId   String?
  sku         String
  description String
  quantity    Int
  price       Float
  isExempt    Boolean  @default(false) // Art 7.8
  taxRate     Float    @default(16.0)
  total       Float
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
}

model InvoiceAudit {
  id          String   @id @default(cuid())
  invoiceId   String
  action      String   // created, cancelled, synced
  userId      String?
  createdAt   DateTime @default(now())
  notes       String?
  
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
}
// --- Payroll Module (LOTTT Venezuela) ---
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model JobPosition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id              String   @id @default(cuid())
  employeeCode    String?  @unique
  firstName       String
  middleName      String?
  lastName        String
  secondLastName  String?
  nationality     String   @default("V") // V, E, P
  idNumber        String   @unique // Cédula
  rif             String?  @unique
  birthDate       DateTime?
  birthPlace      String?
  birthState      String?
  gender          String?  // M, F
  maritalStatus   String?  // Soltero, Casado, etc.
  email           String?
  phone           String?
  address         String?
  address2        String?
  address3        String?
  phone2          String?
  mobilePhone     String?
  pin             String?
  
  // Job Info
  position        String?
  department      String?
  functionalUnit  String?
  group           String?
  businessUnit    String?
  costCenter      String?
  shift           String?  // S, M, T, N
  employeeCondition String? // Activo, Inactivo, etc.
  payrollType     String?  // Semanal, Quincenal, etc.
  category        String?  // Obrero, Empleado, etc.
  instructionLevel String?
  professionalStart DateTime?
  hireDate        DateTime
  terminationDate DateTime?
  exitDate        DateTime?
  exitMotive      String?
  tabulator       Float    @default(0)
  contractEndDate DateTime?
  vacationStartDate DateTime?
  vacationEndDate DateTime?
  lastSocialBenefitsDeposit DateTime?
  isActive        Boolean  @default(true)
  
  // Salary Info
  salaryType      String   @default("MONTHLY") // MONTHLY, DAILY
  baseSalary      Float    @default(0) // Sueldo base
  
  // Bank & Benefits Info
  paymentMethod   String?  // Efectivo, Depósito, etc.
  bankName        String?
  accountNumber   String?
  accountType     String?
  savingsAccount  String?
  savingsEmployeeContribution Float @default(0)
  savingsCompanyContribution Float @default(0)
  foodPension     Float    @default(0)
  utilitiesPercentage Float @default(0)
  medicalLeavePercentage Float @default(0)
  islrQ1          Float    @default(0)
  islrQ2          Float    @default(0)
  islrQ3          Float    @default(0)
  islrQ4          Float    @default(0)
  unionFee        Float    @default(0)
  vehicle         Float    @default(0)
  deductSSO       Boolean  @default(true)
  deductFAOV      Boolean  @default(true)
  hcmRetention    Float    @default(0)
  benefitsDestination String?
  trustAccount142 String?

  // Personal identifiers
  passportNumber  String?
  militaryService String?
  ssn             String?
  licenseGrade    String?
  handedness      String?  // Diestro, Zurdo
  height          Float    @default(0)
  weight          Float    @default(0)
  fingerprintId   String?
  
  payrollDetails  PayrollDetail[]
  fixedConcepts   EmployeeConcept[]
  loans           Loan[]
  familyDependents FamilyDependent[]
  islrPercentage  Float    @default(0) // Percentage from AR-I
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FamilyDependent {
  id              String   @id @default(cuid())
  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  relationship    String   // HIJO, CONYUGE, PADRE, MADRE, OTRO
  birthDate       DateTime
  idNumber        String?  // Optional for children
  gender          String?  // M, F
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payroll {
  id              String   @id @default(cuid())
  type            String   @default("QUINCENAL") // QUINCENAL, MENSUAL, ESPECIAL
  period          String   // e.g., "2024-03-01 al 2024-03-15"
  description     String?  // Custom title for the receipt
  startDate       DateTime
  endDate         DateTime
  status          String   @default("DRAFT") // DRAFT, PROCESSED, CLOSED, CANCELLED
  totalEarnings   Float    @default(0)
  totalDeductions Float    @default(0)
  totalNet        Float    @default(0)
  
  details         PayrollDetail[]
  createdAt       DateTime @default(now())
}

model PayrollDetail {
  id              String   @id @default(cuid())
  payrollId       String
  employeeId      String
  
  // Snapshots at time of processing
  employeeName    String
  employeeIdNumber String
  baseSalary      Float
  
  totalEarnings   Float    @default(0)
  totalDeductions Float    @default(0)
  totalNet        Float    @default(0)
  
  items           PayrollItem[]
  
  payroll         Payroll  @relation(fields: [payrollId], references: [id])
  employee        Employee @relation(fields: [employeeId], references: [id])
}

model PayrollItem {
  id              String   @id @default(cuid())
  payrollDetailId String
  conceptId       String?
  code            String   // e.g., 001, 501
  name            String   // Sueldo, IVSS, LPH
  type            String   // EARNING, DEDUCTION
  amount          Float
  
  payrollDetail   PayrollDetail @relation(fields: [payrollDetailId], references: [id])
}

model PayrollConcept {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  type            String   // EARNING, DEDUCTION
  category        String   // FIXED, FORMULA, MANUAL
  formula         String?  // e.g., "salary / 30 * days"
  isActive        Boolean  @default(true)
  isStatutory     Boolean  @default(false) // IVSS, LPH, etc.
  employeeConcepts EmployeeConcept[]
}

model EmployeeConcept {
  id              String   @id @default(cuid())
  employeeId      String
  conceptId       String
  amount          Float?   // Fixed amount if not by formula
  isActive        Boolean  @default(true)
  
  employee        Employee       @relation(fields: [employeeId], references: [id])
  concept         PayrollConcept @relation(fields: [conceptId], references: [id])
  
  @@unique([employeeId, conceptId])
}

model PayrollConstant {
  id              String   @id @default(cuid())
  key             String   @unique // e.g., UNIDAD_TRIBUTARIA
  name            String
  value           Float
  description     String?
  updatedAt       DateTime @updatedAt
}

model Loan {
  id              String   @id @default(cuid())
  employeeId      String
  amount          Float
  description     String?
  startDate       DateTime
  totalInstallments Int
  remainingInstallments Int
  installmentAmount Float
  status          String   @default("ACTIVE") // ACTIVE, PAID, CANCELLED
  
  employee        Employee @relation(fields: [employeeId], references: [id])
  installments    LoanInstallment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LoanInstallment {
  id              String   @id @default(cuid())
  loanId          String
  payrollDetailId String?  // Linked to the payroll that paid it
  amount          Float
  paidAt          DateTime @default(now())
  
  loan            Loan     @relation(fields: [loanId], references: [id])
}

model PayrollParameter {
  id              String   @id @default("payroll-params")
  minWage         Float    @default(130) // Sueldo Mínimo
  mealTicket      Float    @default(0)   // Cestaticket
  taxUnit         Float    @default(9)   // Unidad Tributaria
  ivssRate        Float    @default(0.04)
  faovRate        Float    @default(0.01)
  lpeRate         Float    @default(0.005)
  maxIvssSalary   Float    @default(5)   // Max 5 salaries for IVSS cap
  islrThreshold   Float    @default(1000) // UT per year threshold
  updatedAt       DateTime @updatedAt
}

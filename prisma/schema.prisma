// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// Global Database Schema (System Level)
model Company {
  id          String        @id @default(cuid())
  name        String
  rif         String        @unique // Tax identification (Venezuela)
  address     String // Required by SENIAT
  phone       String? // Recommended for invoice header
  website     String?
  databaseUrl String // To connect to the tenant-specific database
  status      String        @default("active") // active, suspended, etc.
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       UserCompany[]
}

model User {
  id                String              @id @default(cuid())
  username          String              @unique
  password          String // Should be hashed
  realName          String?
  position          String?             @default("Consultor")
  department        String?             @default("Administración")
  photo             String?             // URL or Base64
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  companies         UserCompany[]
  sessions          Session[]
}

// Pivot table for Multi-company access
model UserCompany {
  userId    String
  companyId String
  role      String  @default("operator") // Legacy role
  profileId String? // New profile link
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])
  profile   Profile? @relation(fields: [profileId], references: [id])

  @@id([userId, companyId])
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  companyId   String?  // Null for system-wide profiles
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  memberships UserCompany[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

